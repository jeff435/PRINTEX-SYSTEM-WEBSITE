rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core security rule enforcing private isolated user access:
    // A user can read/write inside 'users/{userId}/...' only if their authenticated uid matches the userId.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Delivery statuses accessible publicly via QR codes
    match /public_deliveries/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null; // Authenticated dashboard users can create/update
    }

    // Fallback: Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
